# Virtual environments
.venv/
venv/
env/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Logs (optional — comment out if you want to track alerts)
logs/*.jsonl

# ML model (large binary — track separately if needed)
# models/*.pkl

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Secrets / config overrides
*.env
.env

# Remove the pcap files from git tracking
echo "captures/" >> .gitignore
echo "*.pcap" >> .gitignore
echo ".flask_secret" >> .gitignore
echo ".flask_salt" >> .gitignore

# Remove them from git without deleting the files
git rm --cached captures/attack.pcap
git rm --cached capture.pcap

# Commit the fix
git add .gitignore
git commit -m "remove large pcap files and secrets from tracking"

# Force push to fix the rejected commit
git push origin main

captures/
*.pcap
.flask_secret
.flask_salt
